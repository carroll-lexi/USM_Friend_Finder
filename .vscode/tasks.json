{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build friend finder",
            "type": "process",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-g",
                "${workspaceFolder}\\main.cpp",
                "${workspaceFolder}\\Graph.cpp",
                "${workspaceFolder}\\FileIO.cpp",
                "-o",
                "${workspaceFolder}\\main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}